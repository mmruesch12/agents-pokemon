# LangSmith tracing (optional but recommended)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pokemon-gold-agent
LANGCHAIN_TRACING_V2=true

# OpenAI or compatible LLM (used by agent nodes)
OPENAI_API_KEY=

# Game ROM path (user-provided legal dump)
ROM_PATH=roms/pokemon_gold.gb

# Persistence paths
SAVE_DIR=saves
DATA_DIR=data
CHECKPOINT_DB=data/checkpoints.sqlite

# Runner defaults
MAX_STEPS=5000
STUCK_THRESHOLD=10