# LangSmith tracing (optional but recommended)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pokemon-gold-agent
LANGCHAIN_TRACING_V2=true
# Keep full inputs/outputs/metadata in traces (set by --langsmith; override here if needed)
LANGSMITH_HIDE_INPUTS=false
LANGSMITH_HIDE_OUTPUTS=false
LANGSMITH_HIDE_METADATA=false

# LLM for agent nodes — OpenRouter is preferred by default.
# Get a free/low-cost key at https://openrouter.ai/keys and paste it below.
# The first non-empty key wins (OPENROUTER > XAI > OPENAI).
# deepseek/deepseek-v4-flash is the default model when using OpenRouter.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# xAI Grok (alternative)
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-1-fast-reasoning

# OpenAI (alternative)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Game ROM path (user-provided legal dump)
ROM_PATH=roms/pokemon_gold.gb

# Persistence paths
SAVE_DIR=saves
DATA_DIR=data
CHECKPOINT_DB=data/checkpoints.sqlite

# Runner defaults
MAX_STEPS=5000
STUCK_THRESHOLD=10