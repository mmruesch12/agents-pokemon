# LangSmith tracing (optional but recommended)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pokemon-gold-agent
LANGCHAIN_TRACING_V2=true

# LLM for agent nodes (xAI Grok preferred; OpenAI also supported)
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-1-fast-reasoning
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Game ROM path (user-provided legal dump)
ROM_PATH=roms/pokemon_gold.gb

# Persistence paths
SAVE_DIR=saves
DATA_DIR=data
CHECKPOINT_DB=data/checkpoints.sqlite

# Runner defaults
MAX_STEPS=5000
STUCK_THRESHOLD=10